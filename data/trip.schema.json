{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uk-road-trip.local/schemas/trip.schema.json",
  "title": "Travel platform trip document",
  "type": "object",
  "required": ["schemaVersion", "dataRevision", "lastUpdated", "activeTripId", "trips", "trip", "drivingGuide", "tubePlan", "budgetCategories", "currencyRates", "integrations", "travelModules", "noteCategories", "notes", "days", "places", "bookings", "expenses", "checklists", "contacts", "flights", "carRentals", "travelDocuments", "weather", "travelCompanions", "notifications", "priceHistory", "accommodationStops", "hotelOptions"],
  "properties": {
    "schemaVersion": { "const": 10 },
    "dataRevision": { "type": "integer", "minimum": 1 },
    "lastUpdated": { "type": "string", "format": "date-time" },
    "activeTripId": { "$ref": "#/$defs/id" },
    "trips": { "type": "array", "items": { "$ref": "#/$defs/tripSummary" }, "minItems": 1 },
    "trip": { "$ref": "#/$defs/trip" },
    "drivingGuide": { "$ref": "#/$defs/drivingGuide" },
    "tubePlan": { "$ref": "#/$defs/tubePlan" },
    "budgetCategories": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "currencyRates": { "$ref": "#/$defs/currencyRates" },
    "integrations": { "$ref": "#/$defs/integrations" },
    "travelModules": { "type": "array", "items": { "$ref": "#/$defs/travelModule" }, "minItems": 1 },
    "noteCategories": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "notes": { "type": "array", "items": { "$ref": "#/$defs/note" } },
    "days": { "type": "array", "items": { "$ref": "#/$defs/day" }, "minItems": 1 },
    "places": { "type": "array", "items": { "$ref": "#/$defs/place" } },
    "bookings": { "type": "array", "items": { "$ref": "#/$defs/booking" } },
    "expenses": { "type": "array", "items": { "$ref": "#/$defs/expense" } },
    "checklists": { "type": "array", "items": { "$ref": "#/$defs/checklist" } },
    "contacts": { "type": "array", "items": { "$ref": "#/$defs/contact" } },
    "flights": { "type": "array", "items": { "$ref": "#/$defs/travelItem" } },
    "carRentals": { "type": "array", "items": { "$ref": "#/$defs/travelItem" } },
    "travelDocuments": { "type": "array", "items": { "$ref": "#/$defs/travelItem" } },
    "weather": { "type": "array", "items": { "$ref": "#/$defs/travelItem" } },
    "travelCompanions": { "type": "array", "items": { "$ref": "#/$defs/travelItem" } },
    "notifications": { "type": "array", "items": { "$ref": "#/$defs/notification" } },
    "priceHistory": { "type": "array", "items": { "$ref": "#/$defs/pricePoint" } },
    "accommodationStops": { "type": "array", "items": { "$ref": "#/$defs/accommodationStop" } },
    "hotelOptions": { "type": "array", "items": { "$ref": "#/$defs/hotelOption" } }
  },
  "additionalProperties": false,
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]*$" },
    "status": { "type": "string", "enum": ["idea", "researching", "planned", "confirmed", "paid", "cancelled"] },
    "tripSummary": {
      "type": "object",
      "required": ["id", "name", "startDate", "endDate", "homeCurrency", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "name": { "type": "string" }, "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" }, "homeCurrency": { "type": "string", "pattern": "^[A-Z]{3}$" }, "status": { "type": "string" }
      },
      "additionalProperties": false
    },
    "currencyRates": {
      "type": "object",
      "required": ["base", "rates", "lastUpdated"],
      "properties": {
        "base": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "rates": { "type": "object", "additionalProperties": { "type": "number", "exclusiveMinimum": 0 } },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "integrations": {
      "type": "object",
      "required": ["enabled", "defaultProviders"],
      "properties": {
        "enabled": { "type": "boolean" },
        "defaultProviders": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "travelModule": {
      "type": "object",
      "required": ["id", "route", "title", "eyebrow", "collection", "icon", "tone", "summary"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "route": { "$ref": "#/$defs/id" }, "title": { "type": "string" }, "eyebrow": { "type": "string" },
        "collection": { "type": "string" }, "type": { "type": "string" }, "icon": { "type": "string" }, "tone": { "type": "string" }, "summary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "drivingGuide": {
      "type": "object",
      "required": ["units", "emergencyNumber", "lastReviewed", "sourceUrl", "rules"],
      "properties": {
        "units": { "type": "string" }, "emergencyNumber": { "type": "string" }, "breakdownNumber": { "type": "string" },
        "lastReviewed": { "type": "string", "format": "date" }, "sourceUrl": { "type": "string" },
        "rules": { "type": "array", "items": { "type": "object", "required": ["id", "title", "detail"], "properties": { "id": { "$ref": "#/$defs/id" }, "title": { "type": "string" }, "detail": { "type": "string" } }, "additionalProperties": false } }
      },
      "additionalProperties": false
    },
    "tubePlan": {
      "type": "object", "required": ["lastReviewed", "sourceUrl", "paymentNote", "journeys"],
      "properties": {
        "lastReviewed": { "type": "string", "format": "date" }, "sourceUrl": { "type": "string" }, "paymentNote": { "type": "string" },
        "journeys": { "type": "array", "items": { "$ref": "#/$defs/tubeJourney" } }
      }, "additionalProperties": false
    },
    "tubeJourney": {
      "type": "object", "required": ["id", "date", "time", "from", "to", "route", "durationMinutes", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "date": { "type": "string", "format": "date" }, "time": { "type": "string" },
        "from": { "type": "string" }, "to": { "type": "string" }, "route": { "type": "string" }, "durationMinutes": { "type": "integer", "minimum": 0 },
        "status": { "$ref": "#/$defs/status" }, "accessibility": { "type": "string" }, "notes": { "type": "string" }
      }, "additionalProperties": false
    },
    "trip": {
      "type": "object",
      "required": ["id", "name", "startDate", "endDate", "homeCurrency", "budget"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "name": { "type": "string", "minLength": 1 }, "subtitle": { "type": "string" },
        "startDate": { "type": "string", "format": "date" }, "endDate": { "type": "string", "format": "date" },
        "homeCurrency": { "type": "string", "pattern": "^[A-Z]{3}$" }, "budget": { "type": "number", "minimum": 0 },
        "heroImage": { "type": "string" }, "travelers": { "type": "array", "items": { "type": "string" } },
        "vehicle": { "type": "object" }, "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "day": {
      "type": "object", "required": ["id", "date", "title", "region", "country", "activities"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "date": { "type": "string", "format": "date" }, "title": { "type": "string", "minLength": 1 },
        "region": { "type": "string" }, "country": { "type": "string" }, "summary": { "type": "string" }, "distanceMiles": { "type": "number", "minimum": 0 },
        "driveMinutes": { "type": "integer", "minimum": 0 }, "overnightPlaceId": { "type": ["string", "null"] },
        "activities": { "type": "array", "items": { "$ref": "#/$defs/activity" } }
      }, "additionalProperties": false
    },
    "activity": {
      "type": "object", "required": ["id", "type", "title", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "time": { "type": "string", "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$" },
        "type": { "type": "string", "enum": ["attraction", "drive", "hotel", "restaurant", "transport", "walk", "note"] },
        "title": { "type": "string", "minLength": 1 }, "placeId": { "type": "string" }, "status": { "$ref": "#/$defs/status" }, "notes": { "type": "string" }
      }, "additionalProperties": false
    },
    "place": {
      "type": "object", "required": ["id", "type", "name", "city", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "type": { "type": "string", "enum": ["hotel", "restaurant", "attraction", "transport"] },
        "name": { "type": "string", "minLength": 1 }, "city": { "type": "string" }, "address": { "type": "string" },
        "lat": { "type": ["number", "null"], "minimum": -90, "maximum": 90 }, "lng": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
        "phone": { "type": "string" }, "website": { "type": "string" }, "status": { "$ref": "#/$defs/status" },
        "price": { "type": "number", "minimum": 0 }, "bookingReference": { "type": "string" },
        "checkIn": { "type": "string" }, "checkOut": { "type": "string" }, "parking": { "type": "string" }, "notes": { "type": "string" },
        "cuisine": { "type": "string" }, "reservationDate": { "type": "string" }, "reservationTime": { "type": "string" }, "reservationReference": { "type": "string" },
        "openingHours": { "type": "string" }, "bookingRequired": { "type": "boolean" }, "ticketReference": { "type": "string" }, "durationMinutes": { "type": "integer", "minimum": 0 }
      }, "additionalProperties": false
    },
    "booking": {
      "type": "object", "required": ["id", "type", "title", "date", "status", "cost"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "type": { "type": "string" }, "title": { "type": "string" }, "placeId": { "type": "string" },
        "date": { "type": "string", "format": "date" }, "reference": { "type": "string" }, "status": { "$ref": "#/$defs/status" },
        "cost": { "type": "number", "minimum": 0 }, "notes": { "type": "string" }
      }, "additionalProperties": false
    },
    "expense": {
      "type": "object", "required": ["id", "date", "category", "description", "amount", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "date": { "type": "string", "format": "date" }, "category": { "type": "string" },
        "description": { "type": "string", "minLength": 1 }, "amount": { "type": "number", "minimum": 0 }, "status": { "$ref": "#/$defs/status" }, "placeId": { "type": "string" }
      }, "additionalProperties": false
    },
    "checklist": {
      "type": "object", "required": ["id", "type", "title", "items"],
      "properties": { "id": { "$ref": "#/$defs/id" }, "type": { "type": "string", "enum": ["planning", "packing"] }, "title": { "type": "string" }, "items": { "type": "array", "items": { "$ref": "#/$defs/checklistItem" } } },
      "additionalProperties": false
    },
    "checklistItem": {
      "type": "object", "required": ["id", "label", "done"],
      "properties": { "id": { "$ref": "#/$defs/id" }, "label": { "type": "string", "minLength": 1 }, "done": { "type": "boolean" } },
      "additionalProperties": false
    },
    "note": {
      "type": "object", "required": ["id", "title", "body", "category", "pinned", "updatedAt"],
      "properties": { "id": { "$ref": "#/$defs/id" }, "title": { "type": "string", "minLength": 1 }, "body": { "type": "string" }, "category": { "type": "string" }, "dayId": { "type": "string" }, "pinned": { "type": "boolean" }, "updatedAt": { "type": "string", "format": "date-time" } },
      "additionalProperties": false
    },
    "contact": {
      "type": "object", "required": ["id", "label", "value", "type"],
      "properties": { "id": { "$ref": "#/$defs/id" }, "label": { "type": "string" }, "value": { "type": "string" }, "type": { "type": "string", "enum": ["phone", "email", "text"] } },
      "additionalProperties": false
    },
    "travelItem": {
      "type": "object",
      "required": ["id", "title", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "title": { "type": "string", "minLength": 1 }, "provider": { "type": "string" },
        "from": { "type": "string" }, "to": { "type": "string" }, "date": { "type": "string" }, "time": { "type": "string" },
        "pickup": { "type": "string" }, "dropoff": { "type": "string" }, "startDate": { "type": "string" }, "endDate": { "type": "string" },
        "expiryDate": { "type": "string" }, "reference": { "type": "string" }, "status": { "$ref": "#/$defs/status" },
        "price": { "type": "number", "minimum": 0 }, "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "notification": {
      "type": "object",
      "required": ["id", "type", "title", "body", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "type": { "type": "string" }, "title": { "type": "string" }, "body": { "type": "string" },
        "dueDate": { "type": "string" }, "status": { "$ref": "#/$defs/status" }
      },
      "additionalProperties": false
    },
    "pricePoint": {
      "type": "object",
      "required": ["id", "itemId", "providerId", "amount", "currency", "capturedAt"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "itemId": { "type": "string" }, "providerId": { "type": "string" },
        "amount": { "type": "number", "minimum": 0 }, "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "capturedAt": { "type": "string", "format": "date-time" }, "url": { "type": "string" }
      },
      "additionalProperties": false
    },
    "accommodationStop": {
      "type": "object",
      "required": ["id", "location", "dateLabel", "startDate", "endDate", "nights", "image", "status", "optionIds", "notes"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "location": { "type": "string" }, "dateLabel": { "type": "string" },
        "startDate": { "type": "string", "format": "date" }, "endDate": { "type": "string", "format": "date" },
        "nights": { "type": "integer", "minimum": 1 }, "image": { "type": "string" }, "status": { "type": "string" },
        "primaryOptionId": { "$ref": "#/$defs/id" }, "optionIds": { "type": "array", "items": { "$ref": "#/$defs/id" }, "minItems": 1 },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "hotelOption": {
      "type": "object",
      "required": ["id", "location", "overnightPlaceId", "name", "status", "scores", "pros", "cons"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "location": { "type": "string" }, "overnightPlaceId": { "type": "string" },
        "name": { "type": "string", "minLength": 1 }, "area": { "type": "string" }, "role": { "type": "string" }, "status": { "$ref": "#/$defs/status" },
        "price": { "type": "number", "minimum": 0 }, "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "lat": { "type": ["number", "null"], "minimum": -90, "maximum": 90 }, "lng": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
        "nearbyAttractionIds": { "type": "array", "items": { "$ref": "#/$defs/id" } },
        "website": { "type": "string" }, "bookingUrl": { "type": "string" }, "notes": { "type": "string" },
        "bookingStatus": { "type": "string", "enum": ["Researching", "Ready to Book", "Booked", "Cancelled"] },
        "confirmationNumber": { "type": "string" }, "bookedVia": { "type": "string" }, "cancellationDate": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "features": {
          "type": "object",
          "required": ["parking", "breakfast", "kitchen", "laundry", "familyFriendly", "walkScore", "myScore"],
          "properties": {
            "parking": { "type": "boolean" }, "breakfast": { "type": "string" }, "kitchen": { "type": "boolean" },
            "laundry": { "type": "boolean" }, "familyFriendly": { "type": "number", "minimum": 0, "maximum": 10 },
            "walkScore": { "type": "number", "minimum": 0, "maximum": 10 }, "myScore": { "type": "number", "minimum": 0, "maximum": 10 }
          },
          "additionalProperties": false
        },
        "scores": {
          "type": "object",
          "required": ["overall", "value", "comfort", "parking", "breakfast", "kitchen", "laundry", "family", "transport", "loyaltyBenefits"],
          "properties": {
            "overall": { "type": "number", "minimum": 0, "maximum": 10 },
            "value": { "type": "number", "minimum": 0, "maximum": 10 },
            "comfort": { "type": "number", "minimum": 0, "maximum": 10 },
            "parking": { "type": "number", "minimum": 0, "maximum": 10 },
            "breakfast": { "type": "number", "minimum": 0, "maximum": 10 },
            "kitchen": { "type": "number", "minimum": 0, "maximum": 10 },
            "laundry": { "type": "number", "minimum": 0, "maximum": 10 },
            "family": { "type": "number", "minimum": 0, "maximum": 10 },
            "transport": { "type": "number", "minimum": 0, "maximum": 10 },
            "loyaltyBenefits": { "type": "number", "minimum": 0, "maximum": 10 }
          },
          "additionalProperties": false
        },
        "pros": { "type": "array", "items": { "type": "string" } },
        "cons": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
